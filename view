#!/usr/bin/env python3
"""Terminal-friendly wiki page viewer.

Converts [¶N](http://localhost:8765/go.html#N) citations into OSC 8
terminal hyperlinks that display as [¶N] and are Cmd+clickable.
All other markdown links remain as terminal hyperlinks too.
Use: ./view wiki/concepts/balise-installation.md
"""

import re
import sys

CITATION_RE = re.compile(r'\[(¶[\d,\-\s]+?)]\(([^)]+)\)')

def to_osc8(text: str, url: str) -> str:
    """Wrap text in an OSC 8 terminal hyperlink."""
    return f'\033]8;;{url}\033\\{text}\033]8;;\033\\'

def main():
    if len(sys.argv) < 2:
        print(f'Usage: {sys.argv[0]} <path-to-wiki-page>')
        sys.exit(1)

    path = sys.argv[1]
    try:
        with open(path) as f:
            content = f.read()
    except FileNotFoundError:
        print(f'File not found: {path}')
        sys.exit(1)

    def replace(m):
        label = m.group(1)
        url = m.group(2)
        return to_osc8(f'[{label}]', url)

    content = CITATION_RE.sub(replace, content)
    print(content)

if __name__ == '__main__':
    main()
